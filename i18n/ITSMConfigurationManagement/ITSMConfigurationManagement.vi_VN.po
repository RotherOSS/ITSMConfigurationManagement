"hợp này là 'X', \"Content\" phải có giá trị của Trường Động tùy thuộc vào "
"loại Trường Động,  Text: 'a text', Dropdown: '1\", Ngày/Giờ: "
"\"Search_DynamicField_XTimeSlotStartYear=1974; "
"Search_DynamicField_XTimeSlotStartMonth=01; "
"Search_DynamicField_XTimeSlotStartDay=26; "
"Search_DynamicField_XTimeSlotStartHour=00; "
"Search_DynamicField_XTimeSlotStartMinute=00; "
"Search_DynamicField_XTimeSlotStartSecond=00; "
"Search_DynamicField_XTimeSlotStopYear=2013; Tìm "
"kiếm_Trường_Dynamic_XTimeSlot_Tháng_Kết_Thúc=01; Tìm "
"kiếm_Trường_Dynamic_XTimeSlot_Ngày_Kết_Thúc=26; Tìm "
"kiếm_Trường_Dynamic_XTimeSlot_Giờ_Kết_Thúc=23; Tìm "
"kiếm_Trường_Dynamic_XThời_gian_Khoảng_Thời_gian_Kết_thúc_Phút=59; Tìm "
"kiếm_Trường_Dynamic_XThời_gian_Khoảng_Thời_gian_Kết_thúc_Giây=59; 'và hoặc' "
